{
  "_instrucciones": {
    "base_url": "http://localhost:3000/ws/entity-script",
    "header_auth": "fuagentoken: <TU_TOKEN>",
    "como_usar": "Cada objeto es un request HTTP. Copiar el body al cliente HTTP (Postman, Thunder Client, etc). Los casos marcados expect_success:false deben ser rechazados por el sistema."
  },

  "1_CRUD": {
    "1a_crear_script_valido": {
      "method": "POST",
      "url": "/ws/entity-script",
      "body": {
        "name": "actualizar_paciente_fua",
        "description": "Llena datos del paciente en el FUA desde payload de visita",
        "scriptContent": "entity.pacienteNombre = payload.nombres + ' ' + payload.apellidos;\nentity.pacienteDNI = payload.dni;\nentity.fechaAtencion = payload.fechaVisita;\nentity.diagnostico = payload.codigoDiagnostico;",
        "targetEntity": "FUAFormat",
        "maxChars": 2000,
        "maxTimeMs": 1000,
        "createdBy": "test-user"
      },
      "expect_success": true
    },
    "1b_crear_script_con_require": {
      "method": "POST",
      "url": "/ws/entity-script",
      "body": {
        "name": "script_malicioso_require",
        "description": "Intenta usar require",
        "scriptContent": "var fs = require('fs'); entity.x = fs.readFileSync('/etc/passwd');",
        "targetEntity": "FUAFormat",
        "createdBy": "test-user"
      },
      "expect_success": false,
      "expect_error": "bloqueado detectado: \"require\""
    },
    "1c_crear_script_con_process": {
      "method": "POST",
      "url": "/ws/entity-script",
      "body": {
        "name": "script_malicioso_process",
        "description": "Intenta acceder a process",
        "scriptContent": "entity.env = process.env;",
        "targetEntity": "FUAFormat",
        "createdBy": "test-user"
      },
      "expect_success": false,
      "expect_error": "bloqueado detectado: \"process\""
    }
  },

  "2_EJECUCION_AD_HOC": {
    "2a_caso_feliz_asignacion_simple": {
      "method": "POST",
      "url": "/ws/entity-script/execute",
      "body": {
        "entity": {
          "pacienteNombre": "",
          "pacienteDNI": "",
          "fechaAtencion": "",
          "diagnostico": "",
          "establecimiento": ""
        },
        "payload": {
          "nombres": "IGNACIO",
          "apellidos": "TORRES CUETO",
          "dni": "58147747",
          "fechaVisita": "2026-03-25",
          "codigoDiagnostico": "J00",
          "nombreEstablecimiento": "HOSPITAL II-1 SANTA CLOTILDE"
        },
        "script": "entity.pacienteNombre = payload.nombres + ' ' + payload.apellidos;\nentity.pacienteDNI = payload.dni;\nentity.fechaAtencion = payload.fechaVisita;\nentity.diagnostico = payload.codigoDiagnostico;\nentity.establecimiento = payload.nombreEstablecimiento;"
      },
      "expect_success": true,
      "expect_entity": {
        "pacienteNombre": "IGNACIO TORRES CUETO",
        "pacienteDNI": "58147747",
        "diagnostico": "J00"
      }
    },

    "2b_caso_feliz_logica_condicional": {
      "method": "POST",
      "url": "/ws/entity-script/execute",
      "body": {
        "entity": {
          "grupo": "",
          "cobertura": "",
          "requiereAutorizacion": false
        },
        "payload": {
          "edad": 7,
          "tieneSeguroSIS": true,
          "montoTotal": 15000
        },
        "script": "if (payload.edad >= 18) {\n  entity.grupo = 'ADULTO';\n} else if (payload.edad >= 12) {\n  entity.grupo = 'ADOLESCENTE';\n} else {\n  entity.grupo = 'PEDIATRICO';\n}\nentity.cobertura = payload.tieneSeguroSIS ? 'SIS' : 'PARTICULAR';\nentity.requiereAutorizacion = payload.montoTotal > 10000;"
      },
      "expect_success": true,
      "expect_entity": {
        "grupo": "PEDIATRICO",
        "cobertura": "SIS",
        "requiereAutorizacion": true
      }
    },

    "2c_caso_feliz_mapeo_diagnosticos": {
      "method": "POST",
      "url": "/ws/entity-script/execute",
      "body": {
        "entity": {
          "diagnosticoPrincipal": "",
          "diagnosticoSecundario": "",
          "totalDiagnosticos": 0
        },
        "payload": {
          "diagnosticos": [
            { "codigo": "J00", "descripcion": "RINOFARINGITIS AGUDA", "tipo": "DEFINITIVO" },
            { "codigo": "R50.9", "descripcion": "FIEBRE NO ESPECIFICADA", "tipo": "PRESUNTIVO" }
          ]
        },
        "script": "entity.totalDiagnosticos = payload.diagnosticos.length;\nif (payload.diagnosticos.length > 0) {\n  entity.diagnosticoPrincipal = payload.diagnosticos[0].codigo;\n}\nif (payload.diagnosticos.length > 1) {\n  entity.diagnosticoSecundario = payload.diagnosticos[1].codigo;\n}"
      },
      "expect_success": true,
      "expect_entity": {
        "diagnosticoPrincipal": "J00",
        "diagnosticoSecundario": "R50.9",
        "totalDiagnosticos": 2
      }
    },

    "2d_caso_feliz_formatDate": {
      "method": "POST",
      "url": "/ws/entity-script/execute",
      "body": {
        "entity": {
          "fechaRegistro": "",
          "fechaFormateada": ""
        },
        "payload": {
          "fechaISO": "2026-03-25T10:37:40.000+0000"
        },
        "script": "entity.fechaRegistro = formatDate(Date.now());\nentity.fechaFormateada = formatDate(payload.fechaISO);"
      },
      "expect_success": true
    },

    "2e_caso_feliz_calculos_montos": {
      "method": "POST",
      "url": "/ws/entity-script/execute",
      "body": {
        "entity": {
          "montoMedicamentos": 0,
          "montoInsumos": 0,
          "montoProcedimientos": 0,
          "montoTotal": 0
        },
        "payload": {
          "medicamentos": [
            { "nombre": "Paracetamol 500mg", "precio": 2.50, "cantidad": 10 },
            { "nombre": "Amoxicilina 500mg", "precio": 5.00, "cantidad": 21 }
          ],
          "insumos": [
            { "nombre": "Jeringa 5ml", "precio": 0.80, "cantidad": 3 }
          ],
          "procedimientos": [
            { "nombre": "Consulta ambulatoria", "precio": 30.00 }
          ]
        },
        "script": "var totalMed = 0;\nfor (var i = 0; i < payload.medicamentos.length; i++) {\n  totalMed = totalMed + (payload.medicamentos[i].precio * payload.medicamentos[i].cantidad);\n}\nentity.montoMedicamentos = totalMed;\n\nvar totalIns = 0;\nfor (var j = 0; j < payload.insumos.length; j++) {\n  totalIns = totalIns + (payload.insumos[j].precio * payload.insumos[j].cantidad);\n}\nentity.montoInsumos = totalIns;\n\nvar totalProc = 0;\nfor (var k = 0; k < payload.procedimientos.length; k++) {\n  totalProc = totalProc + payload.procedimientos[k].precio;\n}\nentity.montoProcedimientos = totalProc;\nentity.montoTotal = totalMed + totalIns + totalProc;"
      },
      "expect_success": true,
      "expect_entity": {
        "montoMedicamentos": 130,
        "montoInsumos": 2.4000000000000004,
        "montoProcedimientos": 30,
        "montoTotal": 162.4000000000000
      }
    }
  },

